<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:paddingHorizontal="14dp"
    android:paddingTop="12dp"
    android:paddingBottom="14dp">

    <ImageButton
        android:id="@+id/profileButton"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_gravity="end"
        android:layout_marginTop="6dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/profile"
        android:padding="5dp"
        android:src="@android:drawable/ic_menu_myplaces"
        android:tint="@color/white" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="44dp"
        android:gravity="center"
        android:orientation="horizontal">

        <FrameLayout
            android:layout_width="32dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_phone_green">

            <View
                android:layout_width="8dp"
                android:layout_height="3dp"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="6dp"
                android:background="@color/black" />
        </FrameLayout>

        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginStart="9dp"
            android:background="@drawable/bg_dot_green" />

        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_dot_green" />

        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_dot_green" />

        <FrameLayout
            android:layout_width="32dp"
            android:layout_height="56dp"
            android:layout_marginStart="9dp"
            android:background="@drawable/bg_phone_green">

            <View
                android:layout_width="8dp"
                android:layout_height="3dp"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="6dp"
                android:background="@color/black" />
        </FrameLayout>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="18dp"
        android:text="@string/multisaltos"
        android:textColor="@color/rds_green"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:text="@string/home_subtitle"
        android:textColor="@color/white"
        android:textSize="10sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="14dp"
        android:text="@string/stay_safe"
        android:textColor="@color/rds_green"
        android:textSize="22sp"
        android:textStyle="bold" />

    <Space
        android:layout_width="1dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/helpButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_button_help"
        android:text="@string/ask_help"
        android:textAllCaps="true"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:textStyle="bold" />

    <ImageButton
        android:id="@+id/bottomDocButton"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_button_dark"
        android:contentDescription="@string/library"
        android:src="@android:drawable/ic_menu_agenda"
        android:tint="@color/white" />

</LinearLayout>
