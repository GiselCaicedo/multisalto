<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:orientation="vertical"
    android:paddingHorizontal="22dp"
    android:paddingTop="30dp"
    android:paddingBottom="14dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <FrameLayout
                android:id="@+id/themeToggle"
                android:layout_width="92dp"
                android:layout_height="42dp"
                android:layout_gravity="end"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_theme_track_dark"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:padding="3dp">

                <ImageView
                    android:id="@+id/themeTrackLeftIcon"
                    android:layout_width="21dp"
                    android:layout_height="21dp"
                    android:layout_gravity="center_vertical|start"
                    android:layout_marginStart="9dp"
                    android:src="@drawable/ic_theme_clear_figma" />

                <ImageView
                    android:id="@+id/themeTrackRightIcon"
                    android:layout_width="21dp"
                    android:layout_height="21dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="9dp"
                    android:src="@drawable/ic_theme_dark_figma" />

                <FrameLayout
                    android:id="@+id/themeThumb"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_gravity="center_vertical|start"
                    android:background="@drawable/bg_theme_thumb">

                    <ImageView
                        android:id="@+id/themeThumbIcon"
                        android:layout_width="21dp"
                        android:layout_height="21dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_theme_clear_figma" />
                </FrameLayout>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="@string/personal_data"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_input_dark"
                android:hint="@string/sample_name"
                android:paddingHorizontal="12dp"
                android:textColor="@color/white"
                android:textColorHint="#777777"
                android:textSize="10sp" />

            <EditText
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input_dark"
                android:hint="@string/phone_number"
                android:paddingHorizontal="12dp"
                android:textColor="@color/white"
                android:textColorHint="#777777"
                android:textSize="10sp" />

            <Button
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_button_dark"
                android:text="@string/edit_data"
                android:textColor="@color/white"
                android:textSize="9sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:text="@string/emergency_contact_data"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_input_dark"
                android:hint="@string/name_and_lastname"
                android:paddingHorizontal="12dp"
                android:textColor="@color/white"
                android:textColorHint="#777777"
                android:textSize="10sp" />

            <EditText
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input_dark"
                android:hint="@string/phone_number"
                android:paddingHorizontal="12dp"
                android:textColor="@color/white"
                android:textColorHint="#777777"
                android:textSize="10sp" />

            <Button
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_button_dark"
                android:text="@string/edit_data"
                android:textColor="@color/white"
                android:textSize="9sp"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/helpButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_button_red"
        android:text="@string/ask_help"
        android:textAllCaps="true"
        android:textColor="@color/white"
        android:textSize="11sp"
        android:textStyle="bold" />

    <ImageButton
        android:id="@+id/bottomDocButton"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_button_dark"
        android:contentDescription="@string/chat_title"
        android:src="@android:drawable/ic_menu_agenda"
        android:tint="@color/white" />

</LinearLayout>
